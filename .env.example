# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Set to true if you want the bot to also auto-reply inside group chats
REPLY_IN_GROUPS=false

# Optional: customize the bot's personality / instructions
BOT_PERSONALITY=You are a friendly, helpful assistant replying to WhatsApp messages on behalf of the phone's owner. Keep replies short and casual.
